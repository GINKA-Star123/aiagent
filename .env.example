
# ===== App =====
APP_NAME=aiagent
APP_ENV=development
LOG_LEVEL=INFO

# ===== API =====
API_HOST=127.0.0.1
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===== Main LLM =====
LLM_PROVIDER=mock
LLM_MODEL=mock
ENABLE_MOCK_LLM=true
LLM_TIMEOUT_SECONDS=20
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=200

# ===== State / Planner LLM =====
STATE_PROVIDER=mock
STATE_MODEL=mock
ENABLE_MOCK_STATE=true

PLANNER_PROVIDER=mock
PLANNER_MODEL=mock
ENABLE_MOCK_PLANNER=true

# ===== OpenAI-compatible providers =====
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

SILICONFLOW_API=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1

# ===== RAG =====
RAG_EMBEDDING_PROVIDER=huggingface
RAG_EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
RAG_EMBEDDING_MODEL_PATH=
RAG_EMBEDDING_DEVICE=cpu
RAG_EMBEDDING_LOCAL_FILES_ONLY=true
RAG_EMBEDDING_API_KEY_ENV=
RAG_EMBEDDING_BASE_URL=
RAG_EMBEDDING_BATCH_SIZE=64
RAG_EMBEDDING_DIMENSIONS=
RAG_CHUNK_SIZE=520
RAG_CHUNK_OVERLAP=80
RAG_BM25_TOP_K=6
RAG_VECTOR_TOP_K=6
RAG_FINAL_TOP_K=4

# ===== Vision =====
VISION_PROVIDER=mock
VISION_MODEL=
VISION_API_KEY_ENV=
VISION_BASE_URL=
VISION_TIMEOUT_SECONDS=60
VISION_UPLOAD_DIR=data/uploads/images
VISION_MAX_IMAGE_BYTES=12582912

VISION_CHARACTER_ROOT_DIR=data/vision/characters
VISION_CHARACTER_INDEX_DIR=data/cache/vision/character_index
VISION_CHARACTER_EMBEDDING_MODEL_NAME=clip-ViT-B-32
VISION_CHARACTER_EMBEDDING_MODEL_PATH=
VISION_CHARACTER_EMBEDDING_DEVICE=cpu
VISION_CHARACTER_EMBEDDING_LOCAL_FILES_ONLY=false
VISION_CHARACTER_CONFIDENT_SCORE=0.78

# ===== Long-term memory =====
MEMORY_LLM_PROVIDER=openai
MEMORY_LLM_MODEL=gpt-4o-mini
MEMORY_LLM_API_KEY_ENV=OPENAI_API_KEY

MEMORY_EMBEDDER_PROVIDER=openai
MEMORY_EMBEDDER_MODEL=text-embedding-3-small
MEMORY_EMBEDDER_API_KEY_ENV=OPENAI_API_KEY

MEMORY_VECTOR_PROVIDER=qdrant
MEMORY_VECTOR_COLLECTION=aiagent_long_term_memory
MEMORY_EMBEDDING_DIMS=1536
MEMORY_RESET_VECTOR_STORE=false

QDRANT_HOST=localhost
QDRANT_PORT=6333

MEMORY_ENABLE_GRAPH=true
MEMORY_GRAPH_PROVIDER=neo4j
NEO4J_URL=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me-before-production
NEO4J_DATABASE=neo4j

# ===== TTS =====
TTS_PROVIDER=mock
ENABLE_MOCK_TTS=true
ENABLE_LOCAL_AUDIO_PLAYBACK=false
TTS_TIMEOUT_SECONDS=60

GPT_SOVITS_BASE_URL=http://127.0.0.1:9880
GPT_SOVITS_REF_AUDIO_PATH=
GPT_SOVITS_PROMPT_TEXT=你好，欢迎来到直播间。
GPT_SOVITS_PROMPT_LANG=zh
GPT_SOVITS_TEXT_LANG=zh

INDEX_TTS2_BASE_URL=http://127.0.0.1:8000
INDEX_TTS2_REF_AUDIO_PATH=
INDEX_TTS2_EMO_ALPHA=0.6
INDEX_TTS2_USE_EMO_TEXT=true
INDEX_TTS2_MAX_SEGMENT_LENGTH=20

VOXCPM_BASE_URL=

# ===== ASR / Voice =====
ASR_PROVIDER=mock
ENABLE_MOCK_ASR=true
ASR_MODEL_SIZE=medium
ASR_MODEL_PATH=
ASR_DEVICE=cpu
ASR_COMPUTE_TYPE=int8
ASR_LANGUAGE=zh
ASR_SAMPLE_RATE=16000
ASR_RECORD_SECONDS=10

VOICE_CHUNK_SECONDS=0.25
VOICE_MAX_RECORD_SECONDS=8.0
VOICE_SILENCE_SECONDS=1.2
VOICE_ENERGY_THRESHOLD=0.015

# ===== Live2D =====
LIVE2D_PROVIDER=mock
ENABLE_LIVE2D_RUNTIME=false

# ===== Persona fallback =====
PERSONA_NAME=
PERSONA_DESCRIPTION=
PERSONA_STYLE=
PERSONA_RULES=
