APP_ENV=production
APP_NAME=AIAgent
LOG_LEVEL=INFO

CLOUD_MODE=true
CLOUD_DEPLOY_REGION=tencent-cn
API_PUBLIC_BASE_URL=https://your-domain.example.com

API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=https://your-domain.example.com,http://localhost:3000

RATE_LIMIT_ENABLED=true
INFLIGHT_LIMIT_ENABLED=true
LIMITER_FAIL_OPEN=false
REDIS_PREFIX=aiagent:v1

RATE_LIMIT_DEFAULT_PER_MINUTE=60
RATE_LIMIT_CHAT_PER_MINUTE=20
RATE_LIMIT_MULTIMODAL_PER_MINUTE=5
RATE_LIMIT_VOICE_PER_MINUTE=5
RATE_LIMIT_REBUILD_PER_MINUTE=1

GLOBAL_INFLIGHT_LIMIT=100
CHAT_INFLIGHT_LIMIT=40
MULTIMODAL_INFLIGHT_LIMIT=10
VOICE_INFLIGHT_LIMIT=8
REBUILD_INFLIGHT_LIMIT=1
INFLIGHT_LEASE_SECONDS=120

STORAGE_PROVIDER=cos
UPLOAD_MAX_BYTES=26214400
LOCAL_STORAGE_ROOT=data/cloud_storage

S3_ENDPOINT_URL=https://cos.ap-guangzhou.myqcloud.com
S3_REGION=ap-guangzhou
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=https://your-cdn-domain.example.com

QDRANT_HOST=qdrant
QDRANT_PORT=6333

LLM_PROVIDER=openai
LLM_MODEL=your-gpu-llm-model
OPENAI_API_KEY=
OPENAI_BASE_URL=http://your-gpu-llm-endpoint/v1
LLM_TIMEOUT_SECONDS=45
LLM_MAX_TOKENS=600

TTS_PROVIDER=gpt_sovits
ENABLE_MOCK_TTS=false
GPT_SOVITS_BASE_URL=http://your-gpu-tts-endpoint
TTS_TIMEOUT_SECONDS=20

ASR_PROVIDER=faster_whisper
ENABLE_MOCK_ASR=false
ASR_DEVICE=cuda
ASR_COMPUTE_TYPE=float16
ASR_MODEL_SIZE=medium
ASR_MODEL_PATH=
ASR_LANGUAGE=zh

GPU_LLM_BASE_URL=http://your-gpu-llm-endpoint
GPU_TTS_BASE_URL=http://your-gpu-tts-endpoint
GPU_ASR_BASE_URL=http://your-gpu-asr-endpoint

RAG_EMBEDDING_PROVIDER=huggingface
RAG_EMBEDDING_MODEL_PATH=
RAG_EMBEDDING_DEVICE=cpu
RAG_EMBEDDING_LOCAL_FILES_ONLY=true
RAG_EMBEDDING_BATCH_SIZE=32

MEMORY_VECTOR_PROVIDER=qdrant
MEMORY_VECTOR_COLLECTION=aiagent_long_term_memory
MEMORY_EMBEDDING_DIMS=1536
MEMORY_ENABLE_GRAPH=false

VISION_PROVIDER=mock
VISION_UPLOAD_DIR=data/uploads/images
VISION_CHARACTER_ROOT_DIR=data/characters
VISION_CHARACTER_INDEX_DIR=data/cache/vision/character_index

LIVE2D_PROVIDER=mock
ENABLE_LIVE2D_RUNTIME=false

POSTGRES_PASSWORD=change-me-before-production

CLOUD_ADMIN_TOKEN=change-this-admin-token
GPU_API_TOKEN=

WEB_CONCURRENCY=2
WORKER_CONCURRENCY=1
TASK_QUEUE_NAME=default
TASK_POP_TIMEOUT_SECONDS=5
TASK_STALE_SECONDS=1800
TASK_MAX_ATTEMPTS=3

UPLOAD_MAX_BYTES=26214400
PRESENCE_ENABLED=true
PRESENCE_STORAGE=redis
PRESENCE_SESSION_TTL_SECONDS=7776000

